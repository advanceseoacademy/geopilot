# GeoPilot — copy to .env and fill in values

# Supabase: port 6543 (transaction pooler) for Vercel/serverless
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

BETTER_AUTH_SECRET="your-secret-key-min-32-chars"

# Local dev:
NEXT_PUBLIC_APP_URL="http://localhost:3000"
BETTER_AUTH_URL="http://localhost:3000/api/auth"

# Production (https://geopilottools.vercel.app):
# NEXT_PUBLIC_APP_URL="https://geopilottools.vercel.app"
# BETTER_AUTH_URL="https://geopilottools.vercel.app/api/auth"

ADMIN_EMAIL="admin@example.com"
CRON_SECRET="your-cron-secret-for-scheduled-audits"
