generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id
  name            String
  email           String           @unique
  emailVerified   Boolean
  image           String?
  createdAt       DateTime
  updatedAt       DateTime
  projects        Project[]
  Account         Account[]
  Session         Session[]
  teamMembers     TeamMember[]
  apiKeys         ApiKey[]
  ownedTeams      Team[]           @relation("TeamOwner")
  settings        UserSettings?
  scheduledAudits ScheduledAudit[]
  notifications   Notification[]
  bulkJobs        BulkJob[]

  @@map("user")
}

model Session {
  id        String   @id
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model UserSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  scoringWeights   Json?
  webhookUrl       String?
  brandName        String?
  brandLogoUrl     String?
  onboardingDone   Boolean  @default(false)
  notifyOnComplete Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Team {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  ownerId   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  owner     User         @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members   TeamMember[]
  projects  Project[]
  apiKeys   ApiKey[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model ApiKey {
  id        String    @id @default(cuid())
  name      String
  keyHash   String    @unique
  keyPrefix String
  userId    String
  teamId    String?
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
}

model Project {
  id        String   @id @default(cuid())
  name      String
  domain    String
  userId    String
  teamId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  audits    Audit[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
}

model Audit {
  id                    String       @id @default(cuid())
  projectId             String
  url                   String
  status                String       @default("PENDING")
  progress              Int          @default(0)
  progressMsg           String?
  title                 String?
  description           String?
  wordCount             Int?
  geoScore              Float?
  aiReadinessScore      Float?
  citationScore         Float?
  authorityScore        Float?
  entityScore           Float?
  eeatScore             Float?
  contentStructureScore Float?
  internalLinkScore     Float?
  readabilityScore      Float?
  faqScore              Float?
  scoreBreakdown        Json?
  recommendations       Json?
  crawlData             Json?
  robotsData            Json?
  webVitals             Json?
  languageData          Json?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  project               Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entities              Entity[]
  reports               Report[]
  topics                Topic[]
  share                 SharedAudit?

  @@index([projectId, createdAt])
}

model Entity {
  id        String   @id @default(cuid())
  auditId   String
  name      String
  type      String
  count     Int      @default(1)
  createdAt DateTime @default(now())
  audit     Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
}

model Topic {
  id        String   @id @default(cuid())
  auditId   String
  name      String
  type      String
  relevance Float
  createdAt DateTime @default(now())
  audit     Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
}

model Report {
  id        String   @id @default(cuid())
  auditId   String
  pdfUrl    String?
  summary   String?
  createdAt DateTime @default(now())
  audit     Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
}

model ScheduledAudit {
  id        String    @id @default(cuid())
  userId    String
  url       String
  frequency String
  nextRunAt DateTime
  lastRunAt DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SharedAudit {
  id        String   @id @default(cuid())
  auditId   String   @unique
  token     String   @unique
  createdAt DateTime @default(now())
  audit     Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
}

model BulkJob {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("PENDING")
  urls      Json
  results   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
